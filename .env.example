# Copy to .env and edit as needed.
# Defaults are Linux-oriented and repo-relative where possible.

AUTOMOM_COMPUTE_DEVICE="auto"   # auto | cpu | cuda
AUTOMOM_CUDA_DEVICE_ID="0"
# Optional hard kill-switch:
# AUTOMOM_DISABLE_CUDA="1"

AUTOMOM_DIARIZATION_BACKEND="auto"
AUTOMOM_DIARIZATION_MIN_SPEAKERS="0"
AUTOMOM_DIARIZATION_MAX_SPEAKERS="0"
# Local pyannote pipeline path (required for local diarization):
# AUTOMOM_DIARIZATION_MODEL="/abs/path/to/pyannote-speaker-diarization-community-1/config.yaml"
# AUTOMOM_DIARIZATION_PIPELINE="/abs/path/to/pyannote-speaker-diarization-community-1/config.yaml"
AUTOMOM_DIARIZATION_EMBEDDING_MODEL="pyannote/wespeaker-voxceleb-resnet34-LM"
# Optional for gated pyannote models:
# HF_TOKEN="hf_xxx"

AUTOMOM_TRANSCRIPTION_BIN="whisper-cli"
# Default path if unset: data/models/transcription/model.gguf
# AUTOMOM_TRANSCRIPTION_MODEL="/abs/path/to/model.gguf"
# Optional URL/checksum used by Settings > Model Manager download flow.
# AUTOMOM_TRANSCRIPTION_URL="https://example.com/path/to/model.gguf"
# AUTOMOM_TRANSCRIPTION_SHA256="<sha256>"
AUTOMOM_TRANSCRIPTION_THREADS="8"
AUTOMOM_TRANSCRIPTION_PROCESSORS="1"
# Used only when GPU is available and the binary supports GPU flags.
AUTOMOM_TRANSCRIPTION_GPU_LAYERS="99"
AUTOMOM_TRANSCRIPTION_MERGE_GAP_S="1.5"
AUTOMOM_TRANSCRIPTION_MAX_CHUNK_S="20.0"
AUTOMOM_TRANSCRIPTION_KEEP_SEGMENT_AUDIO="0"

AUTOMOM_FORMATTER_BACKEND="ollama" # ollama | command
AUTOMOM_OLLAMA_HOST="http://127.0.0.1:11434"
AUTOMOM_FORMATTER_OLLAMA_MODEL="qwen2.5:3b-instruct-q5_K_M"
# AUTOMOM_OLLAMA_AUTOSTART="1"
# Command backend (used only when AUTOMOM_FORMATTER_BACKEND="command")
# AUTOMOM_FORMATTER_COMMAND='bash -lc "PROMPT_FILE=$(mktemp /tmp/automom_prompt.XXXXXX); cat > \"$PROMPT_FILE\"; llama-cli -m \"{model}\" -n 1024 --temp 0.2 -f \"$PROMPT_FILE\"; STATUS=$?; rm -f \"$PROMPT_FILE\"; exit $STATUS"'
AUTOMOM_FORMATTER_GPU_LAYERS="99"
AUTOMOM_FORMATTER_TIMEOUT_S="300"
