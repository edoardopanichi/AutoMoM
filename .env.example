# Copy to .env and edit if needed

AUTOMOM_DIARIZATION_URL="https://huggingface.co/speechbrain/spkrec-ecapa-voxceleb/resolve/main/embedding_model.ckpt"
AUTOMOM_DIARIZATION_SHA256="0575cb64845e6b9a10db9bcb74d5ac32b326b8dc90352671d345e2ee3d0126a2"
AUTOMOM_DIARIZATION_BACKEND="auto"
AUTOMOM_DIARIZATION_EMBEDDING_MODEL="pyannote/wespeaker-voxceleb-resnet34-LM"
# Optional: when using pyannote backend, point to local pipeline config (YAML or dir)
# AUTOMOM_DIARIZATION_MODEL="/abs/path/to/pyannote_pipeline/config.yaml"
# AUTOMOM_DIARIZATION_PIPELINE="/abs/path/to/pyannote_pipeline/config.yaml"
# Optional for gated pyannote models:
# HF_TOKEN="hf_xxx"

AUTOMOM_VOXTRAL_URL="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-small.bin"
AUTOMOM_VOXTRAL_BIN="whisper-cli"

AUTOMOM_FORMATTER_URL="https://huggingface.co/Triangle104/Qwen2.5-3B-Instruct-Q4_K_M-GGUF/resolve/main/qwen2.5-3b-instruct-q4_k_m.gguf"
AUTOMOM_FORMATTER_SHA256="4761462cc2e813e4eea2ca41f24e85f4350e008e3edf506f0145433376602d9d"
AUTOMOM_FORMATTER_COMMAND='bash -lc "PROMPT_FILE=$(mktemp /tmp/automom_prompt.XXXXXX); cat > \"$PROMPT_FILE\"; llama-cli -m \"{model}\" -n 1024 --temp 0.2 -f \"$PROMPT_FILE\"; STATUS=$?; rm -f \"$PROMPT_FILE\"; exit $STATUS"'
